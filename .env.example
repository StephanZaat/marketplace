# ─── Domain & TLS ──────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
SITE_URL=https://yourdomain.com
LETSENCRYPT_EMAIL=you@example.com

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=marketplace
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://marketplace_user:changeme_in_production@db:5432/marketplace

# ─── Backend ────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_secret
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Auth
JWT_SECRET_KEY=change_this_jwt_secret_too
JWT_EXPIRE_MINUTES=10080

# ─── Object Storage (S3-compatible — leave empty for local storage) ──────────
OBJECTSTORE_ENDPOINT=
OBJECTSTORE_REGION=nl-ams
OBJECTSTORE_ACCESS_KEY=
OBJECTSTORE_SECRET_KEY=
OBJECTSTORE_BUCKET=

# ─── Email (any SMTP provider — Scaleway TEM, Proton, etc.) ────────────────
SMTP_HOST=smtp.tem.scw.cloud
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ─── Friendly Captcha (leave empty to disable) ─────────────────────────────
FRIENDLY_CAPTCHA_SITEKEY=
FRIENDLY_CAPTCHA_SECRET=

# ─── Backup (S3-compatible — leave empty to disable) ────────────────────────
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=
BACKUP_BUCKET=
BACKUP_ENDPOINT=https://s3.nl-ams.scw.cloud
BACKUP_REGION=nl-ams

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password
